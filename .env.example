DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat
EDAN_DUCKDB_PATH=edan_2025_resultat_national_details.duckdb

SQL_DEFAULT_LIMIT=100
QUERY_TIMEOUT_SECONDS=20
QUERY_INTERRUPT_GRACE_SECONDS=2
DUCKDB_MEMORY_LIMIT=256MB
DUCKDB_THREADS=1

RAG_TOP_K=10
ENTITY_SIMILARITY_THRESHOLD=0.80

EDAN_LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=replace_with_your_langfuse_public_key
LANGFUSE_SECRET_KEY=replace_with_your_langfuse_secret_key
LANGFUSE_BASE_URL=https://cloud.langfuse.com
EDAN_LANGFUSE_PROMPTS_ENABLED=true
EDAN_LANGFUSE_PROMPT_LABEL=production
